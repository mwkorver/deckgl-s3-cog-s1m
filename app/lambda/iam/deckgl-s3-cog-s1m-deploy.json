{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CfnReadValidate",
      "Effect": "Allow",
      "Action": [
        "cloudformation:Describe*",
        "cloudformation:Get*",
        "cloudformation:List*",
        "cloudformation:ValidateTemplate"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CfnMutateScoped",
      "Effect": "Allow",
      "Action": [
        "cloudformation:CreateStack",
        "cloudformation:UpdateStack",
        "cloudformation:DeleteStack",
        "cloudformation:CreateChangeSet",
        "cloudformation:ExecuteChangeSet",
        "cloudformation:DeleteChangeSet"
      ],
      "Resource": [
        "arn:aws:cloudformation:us-west-2:__ACCOUNT_ID__:stack/deckgl-s3-cog-s1m-read/*",
        "arn:aws:cloudformation:us-west-2:__ACCOUNT_ID__:stack/deckgl-s3-cog-s1m-read-*/*",
        "arn:aws:cloudformation:us-west-2:__ACCOUNT_ID__:stack/deckgl-s3-cog-s1m-ingest/*",
        "arn:aws:cloudformation:us-west-2:__ACCOUNT_ID__:stack/deckgl-s3-cog-s1m-ingest-*/*",
        "arn:aws:cloudformation:us-west-2:__ACCOUNT_ID__:stack/deckgl-s3-cog-s1m-foundation/*",
        "arn:aws:cloudformation:us-west-2:__ACCOUNT_ID__:stack/aws-sam-cli-managed-default/*",
        "arn:aws:cloudformation:us-west-2:__ACCOUNT_ID__:changeSet/*/*",
        "arn:aws:cloudformation:us-west-2:aws:transform/Serverless-2016-10-31"
      ]
    },
    {
      "Sid": "SamManagedBucket",
      "Effect": "Allow",
      "Action": [
        "s3:CreateBucket",
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:GetBucketPolicy",
        "s3:PutBucketPolicy",
        "s3:PutBucketTagging",
        "s3:PutBucketVersioning",
        "s3:PutEncryptionConfiguration",
        "s3:PutLifecycleConfiguration",
        "s3:PutBucketPublicAccessBlock"
      ],
      "Resource": [
        "arn:aws:s3:::aws-sam-cli-managed-default*",
        "arn:aws:s3:::aws-sam-cli-managed-default*/*"
      ]
    },
    {
      "Sid": "LambdaFnAndLayer",
      "Effect": "Allow",
      "Action": [
        "lambda:CreateFunction",
        "lambda:UpdateFunctionCode",
        "lambda:UpdateFunctionConfiguration",
        "lambda:DeleteFunction",
        "lambda:GetFunction",
        "lambda:GetFunctionConfiguration",
        "lambda:ListVersionsByFunction",
        "lambda:PublishVersion",
        "lambda:TagResource",
        "lambda:UntagResource",
        "lambda:AddPermission",
        "lambda:RemovePermission",
        "lambda:GetPolicy",
        "lambda:PublishLayerVersion",
        "lambda:DeleteLayerVersion",
        "lambda:GetLayerVersion",
        "lambda:ListLayerVersions",
        "lambda:CreateFunctionUrlConfig",
        "lambda:GetFunctionUrlConfig",
        "lambda:UpdateFunctionUrlConfig",
        "lambda:DeleteFunctionUrlConfig"
      ],
      "Resource": [
        "arn:aws:lambda:us-west-2:__ACCOUNT_ID__:function:deckgl-s3-cog-s1m-seed-copy",
        "arn:aws:lambda:us-west-2:__ACCOUNT_ID__:function:deckgl-s3-cog-s1m-read",
        "arn:aws:lambda:us-west-2:__ACCOUNT_ID__:function:deckgl-s3-cog-s1m-ingest",
        "arn:aws:lambda:us-west-2:__ACCOUNT_ID__:function:deckgl-s3-cog-s1m-ingest-worker",
        "arn:aws:lambda:us-west-2:__ACCOUNT_ID__:layer:deckgl-s3-cog-s1m-duckdb",
        "arn:aws:lambda:us-west-2:__ACCOUNT_ID__:layer:deckgl-s3-cog-s1m-duckdb:*"
      ]
    },
    {
      "Sid": "ExecRole",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:GetRole",
        "iam:TagRole",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:GetRolePolicy",
        "iam:ListRolePolicies",
        "iam:ListAttachedRolePolicies"
      ],
      "Resource": [
        "arn:aws:iam::__ACCOUNT_ID__:role/deckgl-s3-cog-s1m-seed-copy",
        "arn:aws:iam::__ACCOUNT_ID__:role/deckgl-s3-cog-s1m-read-*",
        "arn:aws:iam::__ACCOUNT_ID__:role/deckgl-s3-cog-s1m-ingest-*"
      ]
    },
    {
      "Sid": "PassExecRoleToLambda",
      "Effect": "Allow",
      "Action": [
        "iam:PassRole"
      ],
      "Resource": "arn:aws:iam::__ACCOUNT_ID__:role/deckgl-s3-cog-s1m-*",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "lambda.amazonaws.com"
        }
      }
    },
    {
      "Sid": "ViewerBucketAdmin",
      "Effect": "Allow",
      "Action": [
        "s3:CreateBucket",
        "s3:DeleteBucket",
        "s3:GetBucketLocation",
        "s3:GetBucketPolicy",
        "s3:PutBucketPolicy",
        "s3:DeleteBucketPolicy",
        "s3:GetBucketWebsite",
        "s3:PutBucketWebsite",
        "s3:DeleteBucketWebsite",
        "s3:GetBucketPublicAccessBlock",
        "s3:PutBucketPublicAccessBlock",
        "s3:GetBucketOwnershipControls",
        "s3:PutBucketOwnershipControls",
        "s3:GetBucketTagging",
        "s3:PutBucketTagging",
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::deckgl-s3-cog-s1m-__ACCOUNT_ID__-us-west2"
    },
    {
      "Sid": "ViewerBucketList",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::deckgl-s3-cog-s1m-__ACCOUNT_ID__-us-west2"
    },
    {
      "Sid": "ViewerBucketObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::deckgl-s3-cog-s1m-__ACCOUNT_ID__-us-west2/*"
    },
    {
      "Sid": "EcrAuthToken",
      "Effect": "Allow",
      "Action": [
        "ecr:GetAuthorizationToken"
      ],
      "Resource": "*"
    },
    {
      "Sid": "EcrImagePushAndRepo",
      "Effect": "Allow",
      "Action": [
        "ecr:CreateRepository",
        "ecr:DescribeRepositories",
        "ecr:DescribeImages",
        "ecr:ListImages",
        "ecr:TagResource",
        "ecr:SetRepositoryPolicy",
        "ecr:GetRepositoryPolicy",
        "ecr:GetDownloadUrlForLayer",
        "ecr:BatchGetImage",
        "ecr:BatchCheckLayerAvailability",
        "ecr:InitiateLayerUpload",
        "ecr:UploadLayerPart",
        "ecr:CompleteLayerUpload",
        "ecr:PutImage"
      ],
      "Resource": "arn:aws:ecr:us-west-2:__ACCOUNT_ID__:repository/deckgl-s3-cog-s1m-*"
    },
    {
      "Sid": "SamBootstrapParam",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParameter",
        "ssm:GetParameters"
      ],
      "Resource": "arn:aws:ssm:us-west-2:__ACCOUNT_ID__:parameter/aws-sam-cli-managed-default*"
    }
  ]
}
