{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "Lake",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::deckgl-s3-cog-s1m-__ACCOUNT_ID__-us-west2",
        "arn:aws:s3:::deckgl-s3-cog-s1m-__ACCOUNT_ID__-us-west2/*"
      ]
    },
    {
      "Sid": "ManifestIndexReadShared",
      "Effect": "Allow",
      "Action": ["s3:ListBucket", "s3:GetObject"],
      "Resource": [
        "arn:aws:s3:::naip-stac-catalog",
        "arn:aws:s3:::naip-stac-catalog/*"
      ]
    },
    {
      "Sid": "NaipSourceReadRequesterPays",
      "Effect": "Allow",
      "Action": ["s3:ListBucket", "s3:GetObject"],
      "Resource": ["arn:aws:s3:::naip-analytic", "arn:aws:s3:::naip-analytic/*"]
    },
    {
      "Sid": "Whoami",
      "Effect": "Allow",
      "Action": ["sts:GetCallerIdentity"],
      "Resource": "*"
    }
  ]
}
