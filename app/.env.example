# Copy to `.env` for local Docker-based deployment.
#
# AUTH: assume the `cog-stac-deploy` role via SSO. Create the role and profile per
# app/lambda/iam/README.md, then set AWS_PROFILE to it below. docker-compose
# mounts ~/.aws into the API container, so the profile resolves there too.
#
#   AWS_PROFILE=cog-stac-deploy
#
# The role's attached policies (cog-stac-data) already grant requester-pays NAIP
# read (s3:GetObject/ListBucket on naip-analytic), lake read/write, and the
# manifest-index read -- so no inline key/policy is needed here.
# The application sends Requester Pays through S3_COG_REQUEST_PAYER=requester.

AWS_PROFILE=cog-stac-deploy
AWS_REGION=us-west-2
AWS_DEFAULT_REGION=us-west-2

S3_COG_COLLECTION_ID=naip
S3_COG_SIGN_ASSET_URLS=1
S3_COG_PRESIGN_EXPIRES=3600
S3_COG_PRESIGN_CACHE_TTL=900
S3_COG_PRESIGN_CACHE_MAXSIZE=10000
S3_COG_PRESIGN_MAX_WORKERS=8
S3_COG_REQUEST_PAYER=requester

S3_COG_EARTHSEARCH_API=https://earth-search.aws.element84.com/v1/search
S3_COG_EARTHSEARCH_PAGE_SIZE=500
S3_COG_MANIFEST_PATH=/cache/naip-analytic-manifest.txt

# Where local ingest WRITES the app's GeoParquet output. This lives under the
# lake/ prefix of your single per-account bucket created and retained by the
# admin-owned foundation stack (there is no separate lake bucket). Its policy
# keeps lake/ private while serving the viewer files publicly.
#   S3_COG_LAKE_ROOT=s3://cog-stac-viewer-<your-account-id>-us-west-2/lake
# Leave unset and ingest falls back to a local path (cache/exports/...), not S3.
#S3_COG_LAKE_ROOT=

# Shared, author-published NAIP manifest index (READ-only). Leave as-is.
S3_COG_MANIFEST_INDEX=s3://naip-stac-catalog/manifest-index
