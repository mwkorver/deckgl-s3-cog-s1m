# Copy to `.env` for local Docker-based deployment.
#
# AUTH: assume the `cog-stac-deploy` role via SSO. Create the role and profile per
# app/lambda/iam/README.md, then set AWS_PROFILE to it below. docker-compose
# mounts ~/.aws into the API container, so the profile resolves there too.
#
#   AWS_PROFILE=cog-stac-deploy
#
# The role's attached policies (cog-stac-data) already grant requester-pays NAIP
# read (s3:GetObject/ListBucket on naip-analytic), lake read/write, and the
# manifest-index read -- so no inline key/policy is needed here.
# The application sends Requester Pays through S3_COG_REQUEST_PAYER=requester.

AWS_PROFILE=cog-stac-deploy
AWS_REGION=us-west-2
AWS_DEFAULT_REGION=us-west-2

S3_COG_COLLECTION_ID=naip
S3_COG_SIGN_ASSET_URLS=1
S3_COG_PRESIGN_EXPIRES=3600
S3_COG_PRESIGN_CACHE_TTL=900
S3_COG_PRESIGN_CACHE_MAXSIZE=10000
S3_COG_PRESIGN_MAX_WORKERS=8
S3_COG_REQUEST_PAYER=requester

S3_COG_EARTHSEARCH_API=https://earth-search.aws.element84.com/v1/search
S3_COG_EARTHSEARCH_PAGE_SIZE=500
S3_COG_MANIFEST_PATH=/cache/naip-analytic-manifest.txt

# Where local ingest WRITES the app's GeoParquet output (footprint lake, and
# SAM 3 detections later). This lives under the lake/ prefix of your single
# per-account bucket created and retained by the admin-owned foundation stack
# (there is no separate lake bucket). Its policy keeps lake/ + detections/
# private while serving the viewer files publicly.
#   S3_COG_LAKE_ROOT=s3://cog-stac-viewer-<your-account-id>-us-west-2/lake
# Leave unset and ingest falls back to a local path (cache/exports/...), not S3.
#S3_COG_LAKE_ROOT=

# Shared, author-published manifest index (READ-only). Leave as-is.
S3_COG_MANIFEST_INDEX=s3://cog-stac-catalog/manifest-index

# Optional host-only synchronous SAM 3 detection adapter. SAM 3 uses a separate
# numpy<2 environment from this rasterio API. These paths must be visible to the
# host process running uvicorn; they are not available inside Docker Compose.
#SAM3_PYTHON=/Users/you/.venvs/sam3/bin/python
#SAM3_SCRIPT=/Users/you/working/sam-concept-worker/dev/run_sam3_json.py
#SAM3_TIMEOUT_SECONDS=300
# Warm worker (recommended for local dev): a long-lived process loads SAM 3 once
# and serves chips over HTTP, so /detect skips the per-call model load. When set,
# it takes precedence over SAM3_PYTHON/SAM3_SCRIPT. Start it with:
#   PYTORCH_ENABLE_MPS_FALLBACK=1 python dev/serve_sam3.py --port 8765
#SAM3_WORKER_URL=http://127.0.0.1:8765
# Tiling (warm worker only): a large chip_m is covered by a grid of native
# 1008px tiles run in one /infer_batch, then stitched + deduped in world space.
# DEFAULT_TILE_OVERLAP_PX: seam overlap in native px (~126 = 12.5%; raise toward
# 252/25% if you detect big-box-sized objects). MAX_TILES: caps the grid so a
# runaway chip_m can't fan out into hundreds of inferences.
#DEFAULT_TILE_OVERLAP_PX=126
#MAX_TILES=36
